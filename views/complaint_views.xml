<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_swm_complaint_list" model="ir.ui.view">
        <field name="name">otm.swm.complaint.list</field>
        <field name="model">otm.swm.complaint</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'new'"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="bin_id"/>
                <field name="street_id" optional="show"/>
                <field name="association_id" optional="show"/>
                <field name="complaint_type"/>
                <field name="reported_by_name" optional="show"/>
                <field name="report_date"/>
                <field name="is_public" widget="boolean_toggle"
                       optional="show"/>
                <field name="assigned_user_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_swm_complaint_form" model="ir.ui.view">
        <field name="name">otm.swm.complaint.form</field>
        <field name="model">otm.swm.complaint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_assign" type="object"
                            string="Assign to Me" class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_start" type="object"
                            string="Start Work" class="btn-primary"
                            invisible="state != 'assigned'"/>
                    <button name="action_resolve" type="object"
                            string="Resolve" class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state != 'resolved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,assigned,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="bin_id"/>
                            <field name="street_id"/>
                            <field name="association_id"/>
                            <field name="corporation_id"/>
                            <field name="complaint_type"/>
                        </group>
                        <group>
                            <field name="report_date"/>
                            <field name="reported_by_name"/>
                            <field name="reported_by_partner_id"/>
                            <field name="is_public"/>
                            <field name="reporter_ip"
                                   groups="smart_waste_management.group_swm_manager"/>
                            <field name="assigned_user_id"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Photo">
                        <field name="photo" widget="image" nolabel="1"/>
                    </group>
                    <group string="Resolution"
                           invisible="state in ('new', 'assigned')">
                        <field name="resolution" nolabel="1"/>
                        <field name="resolution_date"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_swm_complaint_search" model="ir.ui.view">
        <field name="name">otm.swm.complaint.search</field>
        <field name="model">otm.swm.complaint</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="bin_id"/>
                <field name="association_id"/>
                <field name="reported_by_name"/>
                <filter string="New" name="f_new"
                        domain="[('state', '=', 'new')]"/>
                <filter string="Open" name="f_open"
                        domain="[('state', 'in', ('new', 'assigned', 'in_progress'))]"/>
                <filter string="From Public QR Page" name="f_public"
                        domain="[('is_public', '=', True)]"/>
                <separator/>
                <filter string="Type" name="gb_type"
                        context="{'group_by': 'complaint_type'}"/>
                <filter string="State" name="gb_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Bin" name="gb_bin"
                        context="{'group_by': 'bin_id'}"/>
                <filter string="Report Date" name="gb_date"
                        context="{'group_by': 'report_date:day'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_complaint" model="ir.actions.act_window">
        <field name="name">Complaints</field>
        <field name="res_model">otm.swm.complaint</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_f_open': 1}</field>
    </record>

</odoo>
