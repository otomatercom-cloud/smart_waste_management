<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_swm_street_list" model="ir.ui.view">
        <field name="name">otm.swm.street.list</field>
        <field name="model">otm.swm.street</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="association_id"/>
                <field name="ward_id"/>
                <field name="corporation_id" optional="hide"/>
                <field name="responsible_partner_id"/>
                <field name="bin_count"/>
            </list>
        </field>
    </record>

    <record id="view_swm_street_form" model="ir.ui.view">
        <field name="name">otm.swm.street.form</field>
        <field name="model">otm.swm.street</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Street Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="association_id"/>
                            <field name="ward_id"/>
                            <field name="zone_id"/>
                            <field name="corporation_id"/>
                        </group>
                        <group>
                            <field name="responsible_partner_id"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="location_note"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bins" name="bins">
                            <field name="bin_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="fill_percentage"
                                           widget="progressbar"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_swm_street_search" model="ir.ui.view">
        <field name="name">otm.swm.street.search</field>
        <field name="model">otm.swm.street</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="association_id"/>
                <field name="ward_id"/>
                <filter string="Association" name="gb_assoc"
                        context="{'group_by': 'association_id'}"/>
                <filter string="Ward" name="gb_ward"
                        context="{'group_by': 'ward_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_street" model="ir.actions.act_window">
        <field name="name">Streets</field>
        <field name="res_model">otm.swm.street</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
