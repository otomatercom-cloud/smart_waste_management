<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_swm_reading_list" model="ir.ui.view">
        <field name="name">otm.swm.sensor.reading.list</field>
        <field name="model">otm.swm.sensor.reading</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="create_date"/>
                <field name="bin_id"/>
                <field name="bin_code" optional="hide"/>
                <field name="association_id" optional="show"/>
                <field name="distance_cm"/>
                <field name="fill_percentage"/>
                <field name="battery_level" optional="show"/>
                <field name="signal_strength" optional="hide"/>
                <field name="device_status" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_swm_reading_form" model="ir.ui.view">
        <field name="name">otm.swm.sensor.reading.form</field>
        <field name="model">otm.swm.sensor.reading</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="bin_id"/>
                            <field name="create_date"/>
                            <field name="distance_cm"/>
                            <field name="fill_percentage"/>
                        </group>
                        <group>
                            <field name="battery_level"/>
                            <field name="signal_strength"/>
                            <field name="device_status"/>
                        </group>
                    </group>
                    <group string="Raw Payload">
                        <field name="raw_payload" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_swm_reading_graph" model="ir.ui.view">
        <field name="name">otm.swm.sensor.reading.graph</field>
        <field name="model">otm.swm.sensor.reading</field>
        <field name="arch" type="xml">
            <graph type="line">
                <field name="create_date" interval="hour"/>
                <field name="fill_percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_swm_reading_search" model="ir.ui.view">
        <field name="name">otm.swm.sensor.reading.search</field>
        <field name="model">otm.swm.sensor.reading</field>
        <field name="arch" type="xml">
            <search>
                <field name="bin_id"/>
                <field name="bin_code"/>
                <field name="association_id"/>
                <filter string="Bin" name="gb_bin"
                        context="{'group_by': 'bin_id'}"/>
                <filter string="Association" name="gb_assoc"
                        context="{'group_by': 'association_id'}"/>
                <filter string="Date" name="gb_date"
                        context="{'group_by': 'create_date:day'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_reading" model="ir.actions.act_window">
        <field name="name">Sensor Readings</field>
        <field name="res_model">otm.swm.sensor.reading</field>
        <field name="view_mode">list,graph,form</field>
    </record>

</odoo>
