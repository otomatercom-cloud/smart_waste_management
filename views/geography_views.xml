<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ Corporation / Municipality ============ -->
    <record id="view_swm_corporation_list" model="ir.ui.view">
        <field name="name">otm.swm.corporation.list</field>
        <field name="model">otm.swm.corporation</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="body_type"/>
                <field name="district"/>
                <field name="officer_id"/>
                <field name="bin_count"/>
                <field name="full_bin_count"/>
                <field name="pending_collection_count"/>
                <field name="avg_response_hours" widget="float" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_swm_corporation_form" model="ir.ui.view">
        <field name="name">otm.swm.corporation.form</field>
        <field name="model">otm.swm.corporation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_zones" type="object"
                                class="oe_stat_button" icon="fa-map">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Zones</span>
                            </div>
                        </button>
                        <button name="action_view_bins" type="object"
                                class="oe_stat_button" icon="fa-trash-o">
                            <field name="bin_count" widget="statinfo"
                                   string="Bins"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Corporation Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="body_type"/>
                            <field name="district"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="officer_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group string="Live Metrics">
                        <group>
                            <field name="association_count"/>
                            <field name="street_count"/>
                            <field name="bin_count"/>
                        </group>
                        <group>
                            <field name="available_bin_count"/>
                            <field name="full_bin_count"/>
                            <field name="pending_collection_count"/>
                            <field name="avg_response_hours"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Zones" name="zones">
                            <field name="zone_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="manager_id"/>
                                    <field name="ward_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_swm_corporation_search" model="ir.ui.view">
        <field name="name">otm.swm.corporation.search</field>
        <field name="model">otm.swm.corporation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="district"/>
                <filter string="Corporations" name="f_corp"
                        domain="[('body_type', '=', 'corporation')]"/>
                <filter string="Municipalities" name="f_muni"
                        domain="[('body_type', '=', 'municipality')]"/>
                <filter string="Panchayats" name="f_pan"
                        domain="[('body_type', '=', 'panchayat')]"/>
                <separator/>
                <filter string="Archived" name="f_inactive"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Type" name="gb_type"
                        context="{'group_by': 'body_type'}"/>
                <filter string="District" name="gb_district"
                        context="{'group_by': 'district'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_corporation" model="ir.actions.act_window">
        <field name="name">Corporations / Municipalities</field>
        <field name="res_model">otm.swm.corporation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Corporation / Municipality
            </p>
        </field>
    </record>

    <!-- ============ Zone ============ -->
    <record id="view_swm_zone_list" model="ir.ui.view">
        <field name="name">otm.swm.zone.list</field>
        <field name="model">otm.swm.zone</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="corporation_id"/>
                <field name="manager_id"/>
                <field name="ward_count"/>
            </list>
        </field>
    </record>

    <record id="view_swm_zone_form" model="ir.ui.view">
        <field name="name">otm.swm.zone.form</field>
        <field name="model">otm.swm.zone</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_wards" type="object"
                                class="oe_stat_button" icon="fa-building-o">
                            <field name="ward_count" widget="statinfo"
                                   string="Wards"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Zone Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="corporation_id"/>
                        </group>
                        <group>
                            <field name="manager_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Wards" name="wards">
                            <field name="ward_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="ward_number"/>
                                    <field name="officer_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_swm_zone_search" model="ir.ui.view">
        <field name="name">otm.swm.zone.search</field>
        <field name="model">otm.swm.zone</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="corporation_id"/>
                <filter string="Corporation" name="gb_corp"
                        context="{'group_by': 'corporation_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_zone" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">otm.swm.zone</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============ Ward ============ -->
    <record id="view_swm_ward_list" model="ir.ui.view">
        <field name="name">otm.swm.ward.list</field>
        <field name="model">otm.swm.ward</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="ward_number"/>
                <field name="zone_id"/>
                <field name="corporation_id"/>
                <field name="officer_id"/>
                <field name="association_count"/>
            </list>
        </field>
    </record>

    <record id="view_swm_ward_form" model="ir.ui.view">
        <field name="name">otm.swm.ward.form</field>
        <field name="model">otm.swm.ward</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_associations" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="association_count" widget="statinfo"
                                   string="Associations"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ward Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="ward_number"/>
                            <field name="zone_id"/>
                            <field name="corporation_id"/>
                        </group>
                        <group>
                            <field name="officer_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_swm_ward_search" model="ir.ui.view">
        <field name="name">otm.swm.ward.search</field>
        <field name="model">otm.swm.ward</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ward_number"/>
                <field name="zone_id"/>
                <field name="corporation_id"/>
                <filter string="Zone" name="gb_zone"
                        context="{'group_by': 'zone_id'}"/>
                <filter string="Corporation" name="gb_corp"
                        context="{'group_by': 'corporation_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_swm_ward" model="ir.actions.act_window">
        <field name="name">Wards</field>
        <field name="res_model">otm.swm.ward</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
